# ── Application behaviour ────────────────────────────────────────────────
# Environment: development | staging | production
ENVIRONMENT=production

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Scan interval in seconds (used in continuous monitoring mode)
SCAN_INTERVAL=300

# Scan mode: continuous | once
SCAN_MODE=continuous

# Default symbol and timeframe for analysis
DEFAULT_SYMBOL=SPY
DEFAULT_TIMEFRAME=1D

# ── Data provider ────────────────────────────────────────────────────────
# Provider selection: yfinance (free) | alphavantage | polygon
DEFAULT_PROVIDER=yfinance

# Alpha Vantage — free tier: 5 req/min, 500 req/day
# Get a key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io — basic tier available
# Get a key at https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# ── Alerts — Telegram ───────────────────────────────────────────────────
# Create a bot via @BotFather, then set the token and chat ID.
# Auto-enables Telegram alerts when both values are set.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alerts — Discord ────────────────────────────────────────────────────
# Create an Incoming Webhook in your Discord channel settings.
# Auto-enables Discord alerts when set.
DISCORD_WEBHOOK_URL=

# ── Alerts — Email ──────────────────────────────────────────────────────
# SMTP configuration for email alerts.
# Auto-enables email alerts when EMAIL_SMTP_HOST and EMAIL_RECIPIENT are set.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# ── Alerts — Webhook ────────────────────────────────────────────────────
# Generic webhook URL for custom integrations.
# Auto-enables webhook alerts when set.
WEBHOOK_URL=

# ── Report output ────────────────────────────────────────────────────────
# Directory for generated reports (inside the container)
REPORT_DIR=/data/reports

# Report format: json | csv | html
REPORT_FORMAT=json

# ── Persistent Storage ──────────────────────────────────────────────────
# Storage backend: none (in-memory) | sqlite | postgres
STORAGE_BACKEND=none

# PostgreSQL connection string (required when STORAGE_BACKEND=postgres)
# Used automatically by docker-compose.postgres.yml
# DATABASE_URL=postgresql://appuser:password@postgres:5432/appdb

# PostgreSQL credentials (used by docker-compose.postgres.yml)
# POSTGRES_PASSWORD=defaultpw

# Tip: to enable Postgres via docker compose, set this in .env:
# COMPOSE_FILE=docker-compose.yml:docker-compose.postgres.yml

# ── Web Dashboard ────────────────────────────────────────────────────────
# Enable the web dashboard (true | false)
WEB_ENABLED=false

# Port for the web dashboard
WEB_PORT=8080

# IMPORTANT: Never pass passwords as CLI flags in production —
# they appear in ps aux and docker inspect. Use env vars instead.
WEB_PASSWORD=

# JWT secret for API authentication (auto-generated if empty)
JWT_SECRET=
