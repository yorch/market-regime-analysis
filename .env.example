# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Market Regime Analysis — Environment Configuration                         ║
# ║                                                                             ║
# ║  Copy to .env and fill in your values.                                     ║
# ║  All secrets come in via env vars — never commit real values.              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Data Provider API Keys ──────────────────────────────────────────────────
# At least one provider is needed. Yahoo Finance works without a key.

# Alpha Vantage — free tier: 5 req/min, 500 req/day
# Get a key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io — basic tier available
# Get a key: https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# Yahoo Finance — no key needed (set to any value or leave blank)
# YFINANCE_ENABLED=true

# ── API Server ──────────────────────────────────────────────────────────────

# Host and port for the FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# Number of uvicorn workers (set to 1 when reload=true)
API_WORKERS=1

# Request timeout in seconds
API_TIMEOUT=300

# Enable auto-reload for development (disable in production)
API_RELOAD=false

# ── Authentication ──────────────────────────────────────────────────────────

# IMPORTANT: Change this in production!
JWT_SECRET=your-secret-key-change-in-production

# JWT algorithm (HS256 is recommended)
JWT_ALGORITHM=HS256

# Token expiration in hours
JWT_EXPIRATION_HOURS=24

# ── Rate Limiting ───────────────────────────────────────────────────────────

# Requests per minute per client
RATE_LIMIT_PER_MINUTE=60

# Burst limit for rate limiting
RATE_LIMIT_BURST=10

# ── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (use specific origins in production)
CORS_ORIGINS=*
CORS_METHODS=*
CORS_HEADERS=*

# ── Environment ─────────────────────────────────────────────────────────────

# development | staging | production
ENVIRONMENT=development

# Enable debug mode (shows detailed errors — disable in production)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Database (optional, for future use) ─────────────────────────────────────

# PostgreSQL connection string (used with docker-compose.postgres.yml)
# DATABASE_URL=postgresql://mra:mra_secret@localhost:5432/market_regime
# POSTGRES_USER=mra
# POSTGRES_PASSWORD=mra_secret
# POSTGRES_DB=market_regime

# ── Analysis Defaults ───────────────────────────────────────────────────────

# Default symbol for CLI commands
# DEFAULT_SYMBOL=SPY

# Default data provider (alphavantage | polygon | yfinance)
# DEFAULT_PROVIDER=yfinance
